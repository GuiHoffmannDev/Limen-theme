{%- comment -%}
  Text marquee — a calm ribbon of words that drifts across the page. Uses the
  shared .marquee__track keyframe (animations.css), which already honours
  prefers-reduced-motion. Two identical groups make the loop seamless; the
  second is hidden from assistive tech.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign repeat = s.repeat | times: 1
  assign is_static = false
  unless settings.animations_enabled
    assign is_static = true
  endunless
-%}

<div class="marquee color-{{ s.color_scheme }}{% if is_static %} marquee--static{% endif %}" role="presentation">
  <div class="marquee__viewport">
    <div class="marquee__track marquee--{{ s.font }}" style="--marquee-duration: {{ s.speed }}s;">
      {%- for g in (1..2) -%}
        <span class="marquee__group"{% if forloop.last %} aria-hidden="true"{% endif %}>
          {%- for i in (1..repeat) -%}
            {%- if s.link != blank -%}
              <a href="{{ s.link }}" class="marquee__phrase">{{ s.text | escape }}</a>
            {%- else -%}
              <span class="marquee__phrase">{{ s.text | escape }}</span>
            {%- endif -%}
            <span class="marquee__sep" aria-hidden="true">{{ s.separator | escape }}</span>
          {%- endfor -%}
        </span>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .marquee {
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    padding-block: clamp(1.5rem, 1rem + 2vw, 3rem);
    overflow: hidden;
  }
  .marquee__viewport { width: 100%; overflow: hidden; }
  .marquee__group { display: inline-flex; align-items: center; }
  .marquee__phrase {
    line-height: 1.1;
    letter-spacing: -0.01em;
    padding-inline: 0.4em;
  }
  .marquee--serif .marquee__phrase {
    font-family: var(--font-display, "Instrument Serif", Georgia, serif);
    font-size: clamp(2rem, 1rem + 5vw, 5rem);
  }
  .marquee--sans .marquee__phrase {
    font-family: var(--font-body, "IBM Plex Sans", system-ui, sans-serif);
    font-weight: 500;
    font-size: clamp(1.25rem, 0.8rem + 2.5vw, 2.5rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .marquee__sep { color: rgb(var(--color-accent)); padding-inline: 0.3em; }
  .marquee--serif .marquee__sep { font-size: clamp(1.5rem, 1rem + 4vw, 4rem); }

  .marquee--static .marquee__track { animation: none; }
  .marquee--static .marquee__viewport { display: flex; justify-content: center; }
  .marquee--static .marquee__group:last-child { display: none; }
{% endstylesheet %}

{% schema %}
{
  "name": "Text marquee",
  "tag": "section",
  "class": "marquee-wrapper-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-terracotta"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Cross the threshold"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "—"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "select",
      "id": "font",
      "label": "Typeface",
      "options": [
        { "value": "serif", "label": "Serif (display)" },
        { "value": "sans", "label": "Sans (uppercase)" }
      ],
      "default": "serif"
    },
    {
      "type": "range",
      "id": "repeat",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Repetitions per loop",
      "default": 4
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "s",
      "label": "Loop duration",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Text marquee",
      "settings": {
        "color_scheme": "scheme-terracotta",
        "text": "Cross the threshold"
      }
    }
  ]
}
{% endschema %}
