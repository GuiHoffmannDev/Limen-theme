{%- comment -%}
  Main list-collections — every real Shopify collection presented as an
  editorial directory. Two looks: an image grid of collection cards, or a quiet
  index list (title + product count). Real collection data only; an elegant
  placeholder fills empty cards in the editor.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  case s.sort
    when 'products_desc'
      assign collection_list = collections | sort: 'all_products_count' | reverse
    when 'title'
      assign collection_list = collections | sort: 'title'
    else
      assign collection_list = collections
  endcase
-%}

<section class="collections-section section color-{{ s.color_scheme }}">
  <div class="page-width page-width--wide">
    {%- render 'breadcrumbs' -%}

    <header class="collections-head" data-animate="fade-up">
      <div class="section-header section-header--wide">
        {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
        <h1 class="collections-head__title">{{ s.heading | escape }}</h1>
        {%- if s.intro != blank -%}<p class="section-header__intro">{{ s.intro | escape }}</p>{%- endif -%}
      </div>
    </header>

    {%- if collection_list.size > 0 -%}
      {%- if s.layout == 'list' -%}
        <ul class="collections-index index-list">
          {%- for collection in collection_list -%}
            <li class="index-list__row collections-index__row">
              <a href="{{ collection.url }}" class="index-list__row-title collections-index__link">{{ collection.title }}</a>
              {%- if s.show_count -%}
                <span class="index-list__row-meta">{{ 'products.facets.product_count_simple' | t: count: collection.all_products_count }}</span>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <div class="collections-grid editorial-grid editorial-grid--{{ s.columns }}">
          {%- for collection in collection_list -%}
            {%- liquid
              assign collection_image = collection.image
              if collection_image == blank
                assign collection_image = collection.products.first.featured_image
              endif
            -%}
            <a class="collection-card" href="{{ collection.url }}" data-animate="{{ settings.animation_reveal_style }}" style="--animate-delay: {{ forloop.index0 | times: 70 }}ms;">
              <div class="collection-card__media card__media--ratio-{{ s.image_ratio }}">
                {%- if collection_image != blank -%}
                  {%- render 'responsive-image', image: collection_image, sizes: '(min-width: 990px) 32vw, (min-width: 750px) 45vw, 90vw', widths: '300, 500, 700, 900, 1100', crop: 'center', alt: collection.title -%}
                {%- else -%}
                  <div class="placeholder-svg" aria-hidden="true">{{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg__image' }}</div>
                {%- endif -%}
              </div>
              <div class="collection-card__info">
                <h2 class="collection-card__title">{{ collection.title }}</h2>
                {%- if s.show_count -%}
                  <span class="collection-card__count">{{ 'products.facets.product_count_simple' | t: count: collection.all_products_count }}</span>
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="empty-state">
        <p class="empty-state__title">{{ 'collection.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="button button--outline">{{ 'collection.view_all' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .collections-section { background-color: rgb(var(--color-background)); color: rgb(var(--color-foreground)); }
  .collections-head { margin-bottom: var(--space-xl); }
  .collections-head__title { font-size: calc(var(--text-3xl) * var(--heading-scale, 1)); }

  .collection-card { display: flex; flex-direction: column; gap: var(--space-sm); }
  .collection-card__media { position: relative; overflow: hidden; border-radius: var(--border-radius, 2px); background: rgb(var(--color-foreground) / 0.04); }
  .collection-card__media img,
  .collection-card__media .placeholder-svg { width: 100%; height: 100%; object-fit: cover; transition: transform var(--duration-slow) var(--ease-threshold); }
  .collection-card:hover .collection-card__media img { transform: scale(1.03); }
  .collection-card__info { display: flex; align-items: baseline; justify-content: space-between; gap: 0.75rem; }
  .collection-card__title { font-family: var(--font-display, "Instrument Serif", Georgia, serif); font-size: var(--text-xl); font-weight: 400; line-height: 1.1; }
  .collection-card:hover .collection-card__title { color: rgb(var(--color-accent)); }
  .collection-card__count { flex: none; font-size: var(--text-sm); color: rgb(var(--color-foreground) / 0.55); white-space: nowrap; }

  .collections-index__link { font-family: var(--font-display, "Instrument Serif", Georgia, serif); font-size: var(--text-2xl); font-weight: 400; }
{% endstylesheet %}

{% schema %}
{
  "name": "List collections",
  "tag": "section",
  "class": "main-list-collections-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-ivory"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collections" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Browse by collection" },
    { "type": "text", "id": "intro", "label": "Intro" },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Image grid" },
        { "value": "list", "label": "Index list" }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (4:5)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ],
      "default": "landscape"
    },
    {
      "type": "select",
      "id": "sort",
      "label": "Sort collections",
      "options": [
        { "value": "default", "label": "Default (admin order)" },
        { "value": "title", "label": "Alphabetical" },
        { "value": "products_desc", "label": "Most products first" }
      ],
      "default": "default"
    },
    { "type": "checkbox", "id": "show_count", "label": "Show product count", "default": true }
  ],
  "presets": [{ "name": "List collections" }]
}
{% endschema %}
