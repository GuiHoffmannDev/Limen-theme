{%- comment -%}
  Announcement bar — calm, single-line editorial messages above the header.
  Lives in the header section group. Multiple announcements render inline,
  separated by a subtle middot; on small screens only the first stays visible.
{%- endcomment -%}
{%- if section.blocks.size > 0 -%}
  <div class="announcement-bar color-{{ section.settings.color_scheme }}">
    <div class="page-width page-width--wide announcement-bar__inner">
      <p class="announcement-bar__list">
        {%- for block in section.blocks -%}
          {%- if block.settings.text != blank -%}
            <span class="announcement-bar__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="announcement-bar__link">{{ block.settings.text | escape }}</a>
              {%- else -%}
                {{ block.settings.text | escape }}
              {%- endif -%}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </p>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .announcement-bar {
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    font-size: var(--text-sm);
  }
  .announcement-bar__inner {
    display: flex;
    justify-content: center;
    min-height: 2.5rem;
    padding-block: 0.55rem;
  }
  .announcement-bar__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.4rem 1.1rem;
    max-width: none;
    margin: 0;
    text-align: center;
    letter-spacing: 0.01em;
  }
  .announcement-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 1.1rem;
  }
  .announcement-bar__item:not(:last-child)::after {
    content: "";
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.55;
  }
  .announcement-bar__link {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.22em;
    text-decoration-color: rgb(var(--color-accent) / 0.6);
    transition: text-decoration-color var(--duration-fast) ease;
  }
  .announcement-bar__link:hover { text-decoration-color: rgb(var(--color-accent)); }

  @media (max-width: 749px) {
    .announcement-bar__list { flex-wrap: nowrap; }
    .announcement-bar__item:not(:first-child) { display: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "class": "announcement-bar-section",
  "tag": "aside",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-dark"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping over $150"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "announcement", "settings": { "text": "Free shipping over $150" } },
        { "type": "announcement", "settings": { "text": "Crafted in small batches" } }
      ]
    }
  ]
}
{% endschema %}
