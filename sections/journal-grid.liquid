{%- comment -%}
  Journal — real articles from an editor-selected blog, laid out like a
  magazine contents page: image, date, optional tag/author, serif title and a
  short excerpt. Placeholders appear only in the Theme Editor when no blog is
  selected. Real Shopify blog data only.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign blog = s.blog
  assign has_articles = false
  if blog != blank and blog.articles_count > 0
    assign has_articles = true
  endif
  assign cols = s.columns | times: 1
-%}

<section class="journal section color-{{ s.color_scheme }}">
  <div class="page-width page-width--wide">
    <div class="journal__head" data-animate="{{ settings.animation_reveal_style }}">
      <div class="section-header section-header--wide">
        {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="section-header__title">{{ s.heading | escape }}</h2>{%- endif -%}
        {%- if s.intro != blank -%}<p class="section-header__intro">{{ s.intro | escape }}</p>{%- endif -%}
      </div>
      {%- if s.view_all_label != blank and blog != blank -%}
        <a href="{{ blog.url }}" class="journal__view-all link-arrow">{{ s.view_all_label | escape }}</a>
      {%- endif -%}
    </div>

    {%- if has_articles -%}
      <div class="journal__grid editorial-grid editorial-grid--{{ s.columns }}">
        {%- for article in blog.articles limit: s.articles_to_show -%}
          <article class="journal__card" data-animate="{{ settings.animation_reveal_style }}" style="--animate-delay: {{ forloop.index0 | times: 70 }}ms;">
            <a class="journal__media" href="{{ article.url }}" tabindex="-1" aria-hidden="true">
              {%- if article.image -%}
                {%- render 'responsive-image', image: article.image, sizes: '(min-width: 990px) 32vw, (min-width: 750px) 45vw, 90vw', widths: '300, 500, 700, 900, 1100', alt: article.image.alt -%}
              {%- else -%}
                <div class="placeholder-svg" aria-hidden="true">{{ 'image' | placeholder_svg_tag: 'placeholder-svg__image' }}</div>
              {%- endif -%}
            </a>
            <div class="journal__info">
              <div class="journal__meta">
                {%- if s.show_date -%}<time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%b %d, %Y' }}</time>{%- endif -%}
                {%- if s.show_tag and article.tags.size > 0 -%}<span class="journal__tag">{{ article.tags.first }}</span>{%- endif -%}
              </div>
              <h3 class="journal__title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
              {%- if s.show_excerpt -%}
                {%- assign excerpt = article.excerpt | default: article.content | strip_html | truncatewords: 24 -%}
                {%- if excerpt != blank -%}<p class="journal__excerpt">{{ excerpt }}</p>{%- endif -%}
              {%- endif -%}
              {%- if s.show_author and article.author != blank -%}<p class="journal__author">{{ 'blog.by_author' | t: author: article.author }}</p>{%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- elsif request.design_mode -%}
      <div class="journal__grid editorial-grid editorial-grid--{{ s.columns }}">
        {%- for i in (1..cols) -%}
          <article class="journal__card">
            <div class="journal__media"><div class="placeholder-svg" aria-hidden="true">{{ 'image' | placeholder_svg_tag: 'placeholder-svg__image' }}</div></div>
            <div class="journal__info">
              <div class="journal__meta"><time>{{ 'now' | date: '%b %d, %Y' }}</time></div>
              <h3 class="journal__title">{{ 'onboarding.article_title' | t }}</h3>
            </div>
          </article>
        {%- endfor -%}
      </div>
      <p class="journal__empty">{{ 'onboarding.blog_prompt' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .journal { background-color: rgb(var(--color-background)); color: rgb(var(--color-foreground)); }
  .journal__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }
  .journal__view-all { flex: none; }
  .journal__card { display: flex; flex-direction: column; gap: var(--space-sm); }
  .journal__media { display: block; overflow: hidden; border-radius: var(--border-radius, 2px); aspect-ratio: 3 / 2; background: rgb(var(--color-foreground) / 0.04); }
  .journal__media img,
  .journal__media .placeholder-svg { width: 100%; height: 100%; object-fit: cover; transition: transform var(--duration-slow) var(--ease-threshold); }
  .journal__card:hover .journal__media img { transform: scale(1.03); }
  .journal__info { display: flex; flex-direction: column; gap: 0.5rem; }
  .journal__meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem 1rem; font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.06em; color: rgb(var(--color-foreground) / 0.55); }
  .journal__tag { color: rgb(var(--color-accent)); }
  .journal__title { font-family: var(--font-display, "Instrument Serif", Georgia, serif); font-size: var(--text-xl); font-weight: 400; line-height: 1.12; }
  .journal__title a:hover { color: rgb(var(--color-accent)); }
  .journal__excerpt { font-size: var(--text-sm); line-height: var(--leading-relaxed); color: rgb(var(--color-foreground) / 0.7); max-width: 46ch; }
  .journal__author { font-size: var(--text-xs); color: rgb(var(--color-foreground) / 0.55); }
  .journal__empty { margin-top: var(--space-md); font-size: var(--text-sm); color: rgb(var(--color-foreground) / 0.55); }
{% endstylesheet %}

{% schema %}
{
  "name": "Journal",
  "tag": "section",
  "class": "journal-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-ivory"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Journal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Notes from the threshold"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "Intro"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "All articles"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Articles to show",
      "default": 3
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "3"
    },
    {
      "type": "header",
      "content": "Article details"
    },
    { "type": "checkbox", "id": "show_date", "label": "Show date", "default": true },
    { "type": "checkbox", "id": "show_tag", "label": "Show first tag", "default": true },
    { "type": "checkbox", "id": "show_excerpt", "label": "Show excerpt", "default": true },
    { "type": "checkbox", "id": "show_author", "label": "Show author", "default": false }
  ],
  "presets": [
    {
      "name": "Journal",
      "settings": {
        "color_scheme": "scheme-ivory",
        "columns": "3",
        "articles_to_show": 3
      }
    }
  ]
}
{% endschema %}
