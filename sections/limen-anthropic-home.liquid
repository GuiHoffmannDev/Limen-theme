            "category": "Craft"
          }
        },
        {
          "type": "index_row",
          "settings": {
            "title": "Designing objects that disappear into use",
            "category": "Principles"
          }
        },
        {
          "type": "index_row",
          "settings": {
            "title": "A product system for keyboard, wrist and control",
            "category": "Announcements"
          }
        }
      ]
    }
  ]
}
{% endschema %}
