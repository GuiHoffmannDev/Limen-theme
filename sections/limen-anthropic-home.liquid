{%- comment -%}
  LIMEN Anthropics-style home — editorial product landing page inspired by the
  structure of Anthropic's current site, adapted for Limen technology products.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}

<section class="limen-anthropic color-{{ s.color_scheme }}">
  <div class="page-width page-width--wide limen-anthropic__hero">
    <h1 class="limen-anthropic__hero-title" data-animate="{{ settings.animation_reveal_style }}">
      {{ s.hero_line_1 | escape }}
      <span>{{ s.hero_underlined_1 | escape }}</span>
      {{ s.hero_line_2 | escape }}
      <span>{{ s.hero_underlined_2 | escape }}</span>
    </h1>

    <div class="limen-anthropic__hero-copy" data-animate="fade-up" style="--animate-delay: 120ms;">
      {{ s.hero_body }}
    </div>
  </div>

  <div class="page-width page-width--wide">
    <article class="limen-anthropic__feature" data-animate="fade-up">
      <div class="limen-anthropic__feature-media" aria-hidden="true">
        <img
          src="{{ 'limen-anthropic-field.png' | asset_url }}"
          alt=""
          loading="eager"
          fetchpriority="high"
          width="1536"
          height="1024"
        >
      </div>

      <div class="limen-anthropic__feature-content">
        {%- if s.feature_title != blank -%}
          <h2>{{ s.feature_title | escape }}</h2>
        {%- endif -%}
        {%- if s.feature_body != blank -%}
          <p>{{ s.feature_body | escape }}</p>
        {%- endif -%}
        {%- if s.feature_button_label != blank -%}
          <a href="{{ s.feature_button_link | default: routes.all_products_collection_url }}" class="limen-anthropic__button limen-anthropic__button--light">
            {{ s.feature_button_label | escape }}
            <span aria-hidden="true"></span>
          </a>
        {%- endif -%}
      </div>
    </article>
  </div>

  <div class="page-width page-width--wide limen-anthropic__releases">
    <h2 class="limen-anthropic__section-title">{{ s.releases_heading | escape }}</h2>

    <div class="limen-anthropic__release-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'release' -%}
          <article class="limen-release-card" {{ block.shopify_attributes }} data-animate="fade-up" style="--animate-delay: {{ forloop.index0 | times: 70 }}ms;">
            <div class="limen-release-card__body">
              <h3>{{ block.settings.title | escape }}</h3>
              <p>{{ block.settings.body | escape }}</p>
            </div>

            <div class="limen-release-card__meta">
              <div class="limen-release-card__row">
                <span>{{ block.settings.meta_label_1 | escape }}</span>
                <strong>{{ block.settings.meta_value_1 | escape }}</strong>
              </div>
              <div class="limen-release-card__row">
                <span>{{ block.settings.meta_label_2 | escape }}</span>
                <strong>{{ block.settings.meta_value_2 | escape }}</strong>
              </div>
            </div>

            <a href="{{ block.settings.link | default: routes.all_products_collection_url }}" class="limen-anthropic__button">
              {{ block.settings.button_label | escape }}
              <span aria-hidden="true"></span>
            </a>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="page-width page-width--wide limen-anthropic__index">
    <div class="limen-anthropic__statement">
      {{ s.index_statement }}
    </div>

    <div class="limen-anthropic__rows">
      {%- for block in section.blocks -%}
        {%- if block.type == 'index_row' -%}
          <a class="limen-anthropic__row" href="{{ block.settings.link | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
            <span>{{ block.settings.title | escape }}</span>
            <em>{{ block.settings.category | escape }}</em>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .limen-anthropic {
    --limen-bg: rgb(var(--color-background));
    --limen-fg: rgb(var(--color-foreground));
    --limen-muted: rgb(var(--color-foreground) / 0.64);
    --limen-card: 229 221 207;
    --limen-line: rgb(var(--color-foreground) / 0.16);
    background: var(--limen-bg);
    color: var(--limen-fg);
    padding-bottom: clamp(5rem, 4rem + 7vw, 11rem);
  }

  .limen-anthropic__hero {
    min-height: clamp(34rem, 62vh, 46rem);
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(21rem, 0.88fr);
    align-items: end;
    gap: clamp(3rem, 6vw, 9rem);
    padding-top: clamp(8rem, 7vw, 10rem);
    padding-bottom: clamp(4rem, 6vw, 7rem);
  }

  .limen-anthropic__hero-title {
    max-width: 11.2ch;
    font-family: var(--font-body, "IBM Plex Sans", system-ui, sans-serif);
    font-size: clamp(4.1rem, 1.55rem + 6vw, 7.5rem);
    font-weight: 600;
    line-height: 0.94;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .limen-anthropic__hero-title span {
    text-decoration: underline;
    text-decoration-thickness: 0.06em;
    text-underline-offset: 0.1em;
  }

  .limen-anthropic__hero-copy {
    max-width: 18.5em;
    padding-bottom: clamp(0.5rem, 3vw, 2.5rem);
    font-family: var(--font-display, "Source Serif 4", Georgia, serif);
    font-size: clamp(1.7rem, 0.9rem + 1.85vw, 2.95rem);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .limen-anthropic__hero-copy p {
    max-width: none;
  }

  .limen-anthropic__feature {
    position: relative;
    min-height: clamp(31rem, 59vw, 55rem);
    overflow: hidden;
    border-radius: 12px;
    background: rgb(239 236 225);
    display: grid;
    place-items: center;
    isolation: isolate;
  }

  .limen-anthropic__feature-media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .limen-anthropic__feature-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.82;
  }

  .limen-anthropic__feature-content {
    width: min(100%, 76rem);
    padding: clamp(3rem, 6vw, 7rem) clamp(1.5rem, 4vw, 5rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.35rem;
  }

  .limen-anthropic__feature-content h2 {
    max-width: 11.4ch;
    font-family: var(--font-display, "Source Serif 4", Georgia, serif);
    font-size: clamp(4.4rem, 1rem + 8.4vw, 11rem);
    font-weight: 400;
    line-height: 0.94;
    letter-spacing: 0;
  }

  .limen-anthropic__feature-content p {
    max-width: 49rem;
    font-family: var(--font-body, "IBM Plex Sans", system-ui, sans-serif);
    font-size: clamp(1.1rem, 0.85rem + 0.7vw, 1.55rem);
    line-height: 1.25;
  }

  .limen-anthropic__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    width: fit-content;
    min-height: 3.05rem;
    padding: 0.85rem 1.28rem 0.9rem;
    border: 1px solid rgb(16 16 15);
    border-radius: 8px;
    background: rgb(16 16 15);
    color: rgb(250 249 245);
    font-family: var(--font-body, "IBM Plex Sans", system-ui, sans-serif);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1;
    transition: transform var(--duration-fast) var(--ease-out-soft), background-color var(--duration-fast) ease;
  }

  .limen-anthropic__button--light {
    background: rgb(250 249 245 / 0.82);
    color: rgb(16 16 15);
    backdrop-filter: blur(8px);
  }

  .limen-anthropic__button:hover {
    transform: translateY(-1px);
  }

  .limen-anthropic__button span {
    width: 1.15em;
    height: 0.72em;
    background: currentColor;
    -webkit-mask: url("icon-arrow-right.svg") no-repeat center / contain;
    mask: url("icon-arrow-right.svg") no-repeat center / contain;
    transition: transform var(--duration-base) var(--ease-threshold);
  }

  .limen-anthropic__button:hover span {
    transform: translateX(0.25rem);
  }

  .limen-anthropic__releases {
    padding-top: clamp(5.5rem, 7vw, 9rem);
  }

  .limen-anthropic__section-title {
    margin-bottom: clamp(2rem, 3vw, 3rem);
    font-family: var(--font-body, "IBM Plex Sans", system-ui, sans-serif);
    font-size: clamp(2rem, 1.5rem + 1.4vw, 3rem);
    font-weight: 600;
    letter-spacing: 0;
  }

  .limen-anthropic__release-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.5rem, 2.5vw, 3rem);
  }

  .limen-release-card {
    min-height: clamp(31rem, 37vw, 43rem);
    display: flex;
    flex-direction: column;
    padding: clamp(2rem, 3vw, 3rem);
    border-radius: 18px;
    background: rgb(var(--limen-card));
  }

  .limen-release-card__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .limen-release-card h3 {
    max-width: 12ch;
    font-family: var(--font-body, "IBM Plex Sans", system-ui, sans-serif);
    font-size: clamp(2rem, 1.35rem + 1.7vw, 3rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .limen-release-card p {
    max-width: 23ch;
    font-family: var(--font-display, "Source Serif 4", Georgia, serif);
    font-size: clamp(1.55rem, 1rem + 1vw, 2.15rem);
    line-height: 1.12;
    letter-spacing: 0;
  }

  .limen-release-card__meta {
    margin-top: auto;
    margin-bottom: clamp(1.8rem, 2vw, 2.4rem);
    border-top: 1px solid var(--limen-line);
  }

  .limen-release-card__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.05rem 0;
    border-bottom: 1px solid var(--limen-line);
  }

  .limen-release-card__row span {
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .limen-release-card__row strong {
    font-size: 1.08rem;
    font-weight: 400;
    text-align: right;
  }

  .limen-anthropic__index {
    display: grid;
    grid-template-columns: minmax(16rem, 0.85fr) minmax(0, 2.15fr);
    gap: clamp(3rem, 7vw, 10rem);
    padding-top: clamp(7rem, 9vw, 12rem);
  }

  .limen-anthropic__statement {
    max-width: 13.5ch;
    font-family: var(--font-body, "IBM Plex Sans", system-ui, sans-serif);
    font-size: clamp(2.1rem, 1.5rem + 1.6vw, 3.1rem);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: 0;
  }

  .limen-anthropic__statement p {
    max-width: none;
  }

  .limen-anthropic__rows {
    border-top: 1px solid var(--limen-line);
  }

  .limen-anthropic__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(10rem, auto);
    gap: 2rem;
    align-items: baseline;
    padding: 1.28rem 0;
    border-bottom: 1px solid var(--limen-line);
  }

  .limen-anthropic__row span {
    font-size: clamp(1.15rem, 0.95rem + 0.55vw, 1.55rem);
    font-weight: 600;
  }

  .limen-anthropic__row em {
    justify-self: end;
    font-family: var(--font-body, "IBM Plex Sans", system-ui, sans-serif);
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.25rem);
    font-style: normal;
    color: var(--limen-muted);
  }

  @media (max-width: 989px) {
    .limen-anthropic__hero {
      min-height: auto;
      grid-template-columns: 1fr;
      align-items: start;
      gap: 2rem;
      padding-top: 6rem;
      padding-bottom: 4rem;
    }

    .limen-anthropic__hero-title {
      max-width: 10ch;
      font-size: clamp(3.6rem, 12vw, 6.35rem);
    }

    .limen-anthropic__hero-copy {
      max-width: 19em;
      padding-bottom: 0;
    }

    .limen-anthropic__release-grid {
      grid-template-columns: 1fr;
    }

    .limen-release-card {
      min-height: 27rem;
    }

    .limen-anthropic__index {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .limen-anthropic__statement {
      max-width: 15ch;
    }
  }

  @media (max-width: 749px) {
    .limen-anthropic__hero {
      padding-top: 4.5rem;
    }

    .limen-anthropic__hero-title {
      max-width: 9.5ch;
      font-size: clamp(3rem, 13.5vw, 4.75rem);
      line-height: 0.98;
    }

    .limen-anthropic__hero-copy {
      font-size: clamp(1.45rem, 5.8vw, 2.15rem);
    }

    .limen-anthropic__feature {
      min-height: 34rem;
      border-radius: 0;
      margin-inline: calc(var(--page-margin-mobile) * -1);
    }

    .limen-anthropic__feature-content {
      padding-inline: var(--page-margin-mobile);
    }

    .limen-anthropic__feature-content h2 {
      font-size: clamp(3.4rem, 18vw, 5.8rem);
      line-height: 0.98;
    }

    .limen-release-card {
      min-height: 25rem;
      border-radius: 14px;
    }

    .limen-release-card__row {
      align-items: start;
      flex-direction: column;
      gap: 0.35rem;
    }

    .limen-release-card__row strong {
      text-align: left;
    }

    .limen-anthropic__row {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }

    .limen-anthropic__row em {
      justify-self: start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Limen Anthropic home",
  "tag": "section",
  "class": "limen-anthropic-home-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-warm-white"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_line_1",
      "label": "Hero line 1",
      "default": "Technology"
    },
    {
      "type": "text",
      "id": "hero_underlined_1",
      "label": "Underlined word 1",
      "default": "products"
    },
    {
      "type": "text",
      "id": "hero_line_2",
      "label": "Hero line 2",
      "default": "that make"
    },
    {
      "type": "text",
      "id": "hero_underlined_2",
      "label": "Underlined word 2",
      "default": "interaction human"
    },
    {
      "type": "richtext",
      "id": "hero_body",
      "label": "Hero body",
      "default": "<p>Limen builds tactile tools for focused work: keyboards, wrist supports and quiet desktop objects designed around the body.</p>"
    },
    {
      "type": "header",
      "content": "Feature panel"
    },
    {
      "type": "text",
      "id": "feature_title",
      "label": "Feature title",
      "default": "Objects for the way people think"
    },
    {
      "type": "text",
      "id": "feature_body",
      "label": "Feature body",
      "default": "A small system of hardware made to reduce friction between hands, attention and the work in front of you."
    },
    {
      "type": "text",
      "id": "feature_button_label",
      "label": "Feature button",
      "default": "Explore products"
    },
    {
      "type": "url",
      "id": "feature_button_link",
      "label": "Feature link"
    },
    {
      "type": "header",
      "content": "Releases"
    },
    {
      "type": "text",
      "id": "releases_heading",
      "label": "Heading",
      "default": "Latest releases"
    },
    {
      "type": "header",
      "content": "Index"
    },
    {
      "type": "richtext",
      "id": "index_statement",
      "label": "Statement",
      "default": "<p>At Limen, we design technology to serve the body before the interface.</p>"
    }
  ],
  "blocks": [
    {
      "type": "release",
      "name": "Release card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Limen Keyboard" },
        { "type": "text", "id": "body", "label": "Body", "default": "A low-profile keyboard for long writing sessions, precise shortcuts and calm desk setups." },
        { "type": "text", "id": "meta_label_1", "label": "Meta label 1", "default": "Status" },
        { "type": "text", "id": "meta_value_1", "label": "Meta value 1", "default": "Coming soon" },
        { "type": "text", "id": "meta_label_2", "label": "Meta label 2", "default": "Category" },
        { "type": "text", "id": "meta_value_2", "label": "Meta value 2", "default": "Input devices" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore product" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "index_row",
      "name": "Index row",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Why the wrist support comes before the keyboard" },
        { "type": "text", "id": "category", "label": "Category", "default": "Ergonomics" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Limen Anthropic home",
      "blocks": [
        {
          "type": "release",
          "settings": {
            "title": "Limen Keyboard",
            "body": "A low-profile keyboard for long writing sessions, precise shortcuts and calm desk setups.",
            "meta_value_1": "Coming soon",
            "meta_value_2": "Input devices"
          }
        },
        {
          "type": "release",
          "settings": {
            "title": "Arm Wrist",
            "body": "A weighted wrist support shaped to keep hands relaxed through repeated work.",
            "meta_value_1": "Prototype",
            "meta_value_2": "Ergonomics"
          }
        },
        {
          "type": "release",
          "settings": {
            "title": "Control Module",
            "body": "A small aluminum controller for audio, macros and the transitions of a focused day.",
            "meta_value_1": "In development",
            "meta_value_2": "Desktop tools"
          }
        },
        {
          "type": "index_row",
          "settings": {
            "title": "The keyboard as a threshold for focused work",
            "category": "Product notes"
          }
