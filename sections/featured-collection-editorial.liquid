{%- comment -%}
  Featured collection editorial — products from a real, editor-selected
  collection presented as quiet objects (almost no box, generous gutters,
  optional hover swap + quick add). Elegant placeholders appear only in the
  Theme Editor when no collection is chosen yet. Real Shopify data only.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign collection = s.collection
  assign limit = s.products_to_show
  assign ratio = s.image_ratio
  if ratio == 'inherit'
    assign ratio = settings.card_image_ratio
  endif
  assign col_count = s.columns | times: 1
  assign has_products = false
  if collection != blank and collection.products.size > 0
    assign has_products = true
  endif
  if col_count == 4
    assign grid_sizes = '(min-width: 990px) 22vw, (min-width: 750px) 30vw, 45vw'
  else
    assign grid_sizes = '(min-width: 990px) 30vw, (min-width: 750px) 30vw, 45vw'
  endif
-%}

<section class="featured-collection section color-{{ s.color_scheme }}">
  <div class="page-width page-width--wide">
    <div class="featured-collection__head" data-animate="{{ settings.animation_reveal_style }}">
      <div class="section-header{% if s.intro == blank %} section-header--wide{% endif %}">
        {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="section-header__title">{{ s.heading | escape }}</h2>{%- endif -%}
        {%- if s.intro != blank -%}<p class="section-header__intro">{{ s.intro | escape }}</p>{%- endif -%}
      </div>
      {%- if s.view_all_label != blank and collection != blank -%}
        <a href="{{ collection.url }}" class="featured-collection__view-all link-arrow">{{ s.view_all_label | escape }}</a>
      {%- endif -%}
    </div>

    {%- if has_products -%}
      <div class="featured-collection__grid editorial-grid editorial-grid--{{ s.columns }}">
        {%- for product in collection.products limit: limit -%}
          {%- render 'product-card',
            product: product,
            image_ratio: ratio,
            show_quick_add: s.show_quick_add,
            sizes: grid_sizes,
            index: forloop.index
          -%}
        {%- endfor -%}
      </div>
    {%- elsif request.design_mode -%}
      <div class="featured-collection__grid editorial-grid editorial-grid--{{ s.columns }}">
        {%- for i in (1..col_count) -%}
          <article class="card product-card">
            <div class="card__media card__media--ratio-{{ ratio }}">
              <div class="placeholder-svg" aria-hidden="true">{{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg__image' }}</div>
            </div>
            <div class="card__info">
              <h3 class="card__title">{{ 'onboarding.product_title' | t }}</h3>
              <div class="card__meta"><span class="price"><span class="price__regular">{{ 4800 | money }}</span></span></div>
            </div>
          </article>
        {%- endfor -%}
      </div>
      <p class="featured-collection__empty">{{ 'onboarding.collection_prompt' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .featured-collection { background-color: rgb(var(--color-background)); color: rgb(var(--color-foreground)); }
  .featured-collection__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }
  .featured-collection__view-all { flex: none; }
  .featured-collection__empty {
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: rgb(var(--color-foreground) / 0.55);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-ivory"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Selected objects"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made to remain useful"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "Intro"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View all"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "inherit", "label": "Use theme default" },
        { "value": "natural", "label": "Natural" },
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (4:5)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ],
      "default": "inherit"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured collection",
      "settings": {
        "color_scheme": "scheme-ivory",
        "columns": "4",
        "products_to_show": 4
      }
    }
  ]
}
{% endschema %}
