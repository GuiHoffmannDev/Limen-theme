{%- comment -%}
  Image + text editorial — a focused media/text pairing with an optional small
  caption under the image. Uses the shared .media-text scaffolding.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign reverse = false
  if s.image_position == 'right'
    assign reverse = true
  endif
-%}

<section class="image-text section color-{{ s.color_scheme }}{% if s.show_texture %} has-texture{% endif %}">
  <div class="page-width">
    <div class="media-text{% if reverse %} media-text--reverse{% endif %}{% if s.media_wide %} media-text--media-wide{% endif %} image-text__layout">
      <div class="media-text__media image-text__media" data-animate="{{ settings.animation_reveal_style }}">
        {%- if s.image != blank -%}
          {%- render 'responsive-image', image: s.image, sizes: '(min-width: 750px) 55vw, 100vw', widths: '500, 700, 900, 1200, 1500' -%}
        {%- else -%}
          <div class="placeholder-svg" aria-hidden="true">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg__image' }}</div>
        {%- endif -%}
        {%- if s.caption != blank -%}<p class="image-text__caption">{{ s.caption | escape }}</p>{%- endif -%}
      </div>

      <div class="media-text__content image-text__content" data-animate="fade-up" style="--animate-delay: 100ms;">
        {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="image-text__heading">{{ s.heading | escape }}{% if s.heading_emphasis != blank %} <em>{{ s.heading_emphasis | escape }}</em>{% endif %}</h2>{%- endif -%}
        {%- if s.body != blank -%}<div class="rte image-text__body">{{ s.body }}</div>{%- endif -%}
        {%- if s.cta_label != blank -%}<a href="{{ s.cta_link }}" class="link-arrow image-text__cta">{{ s.cta_label | escape }}</a>{%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .image-text { background-color: rgb(var(--color-background)); color: rgb(var(--color-foreground)); }
  .image-text__media { align-self: center; }
  .image-text__caption { margin-top: 0.6rem; font-size: var(--text-xs); letter-spacing: 0.02em; color: rgb(var(--color-foreground) / 0.55); }
  .image-text__media { overflow: visible; }
  .image-text__media img,
  .image-text__media .placeholder-svg { border-radius: var(--border-radius, 2px); }
  .image-text__content { gap: var(--space-md); }
  .image-text__heading { font-size: calc(var(--text-2xl) * var(--heading-scale, 1)); max-width: 18ch; }
  .image-text__body { color: rgb(var(--color-foreground) / 0.8); line-height: var(--leading-relaxed); }
  .image-text__body > * + * { margin-top: 1em; }
{% endstylesheet %}

{% schema %}
{
  "name": "Image + text",
  "tag": "section",
  "class": "image-text-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-ivory"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "media_wide",
      "label": "Wider image column",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_texture",
      "label": "Add paper texture",
      "default": false
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "In use"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed to be"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading emphasis (italic accent)",
      "default": "reached for."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Objects that sit naturally on a desk, in a hand, in a day — quietly useful, never demanding attention they haven't earned.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "Image + text",
      "settings": {
        "color_scheme": "scheme-ivory"
      }
    }
  ]
}
{% endschema %}
