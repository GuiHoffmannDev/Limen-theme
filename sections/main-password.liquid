{%- comment -%}
  Main password — the storefront lock screen shown while the shop is password
  protected. Native {% form 'storefront_password' %}. Editorial teaser: brand
  lockup, campaign copy, the shop's own password message, an optional newsletter
  sign-up ({% form 'customer' %}) and the store-owner login link. Standalone:
  it renders inside layout/password.liquid (no header/footer).
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign uid = section.id | replace: '-', '' | downcase
  assign social_present = false
  if settings.social_instagram != blank or settings.social_tiktok != blank or settings.social_youtube != blank or settings.social_linkedin != blank or settings.social_x != blank
    assign social_present = true
  endif
-%}

<section class="password section color-{{ s.color_scheme }}{% if s.show_texture %} has-texture{% endif %}">
  <div class="page-width password__wrap">
    <div class="password__inner">
      <a href="{{ routes.root_url }}" class="password__brand" aria-label="{{ shop.name }}">
        {%- render 'brand-logo', inverse: true, width: 150 -%}
      </a>

      <div class="password__content" data-animate="fade-up">
        {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow password__eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
        <h1 class="password__title display">{{ s.heading | escape }}{% if s.heading_emphasis != blank %} <em>{{ s.heading_emphasis | escape }}</em>{% endif %}</h1>
        {%- if s.body != blank -%}<p class="password__body">{{ s.body | escape }}</p>{%- endif -%}
        {%- if shop.password_message != blank -%}<div class="password__message rte">{{ shop.password_message }}</div>{%- endif -%}

        {%- if s.show_newsletter -%}
          <div class="password__newsletter">
            {%- if s.newsletter_heading != blank -%}<p class="password__newsletter-heading">{{ s.newsletter_heading | escape }}</p>{%- endif -%}
            {%- form 'customer', id: 'PasswordNewsletter', class: 'password__newsletter-form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter, password-page">
              {%- if form.posted_successfully? -%}
                <p class="form__message form__message--success" role="status">
                  {%- render 'icon', name: 'check', class: 'icon--sm' -%} {{ 'newsletter.success' | t }}
                </p>
              {%- else -%}
                <label class="visually-hidden" for="PasswordEmail-{{ uid }}">{{ 'newsletter.label' | t }}</label>
                <div class="password__newsletter-field">
                  <input type="email" id="PasswordEmail-{{ uid }}" name="contact[email]" value="{{ form.email }}" placeholder="{{ 'newsletter.placeholder' | t }}" autocomplete="email" required>
                  <button type="submit" class="button button--solid">{{ 'newsletter.button' | t }}</button>
                </div>
                {%- if form.errors -%}<p class="form__message form__message--error" role="alert">{{ 'newsletter.error' | t }}</p>{%- endif -%}
              {%- endif -%}
            {%- endform -%}
          </div>
        {%- endif -%}

        {%- if social_present and s.show_social -%}
          <ul class="password__social cluster" aria-label="{{ 'general.social.label' | t }}">
            {%- if settings.social_instagram != blank -%}<li><a href="{{ settings.social_instagram }}" aria-label="{{ 'general.social.instagram' | t }}" rel="noopener" target="_blank">{%- render 'icon', name: 'instagram', class: 'icon--sm' -%}</a></li>{%- endif -%}
            {%- if settings.social_tiktok != blank -%}<li><a href="{{ settings.social_tiktok }}" aria-label="{{ 'general.social.tiktok' | t }}" rel="noopener" target="_blank">{%- render 'icon', name: 'tiktok', class: 'icon--sm' -%}</a></li>{%- endif -%}
            {%- if settings.social_youtube != blank -%}<li><a href="{{ settings.social_youtube }}" aria-label="{{ 'general.social.youtube' | t }}" rel="noopener" target="_blank">{%- render 'icon', name: 'youtube', class: 'icon--sm' -%}</a></li>{%- endif -%}
            {%- if settings.social_linkedin != blank -%}<li><a href="{{ settings.social_linkedin }}" aria-label="{{ 'general.social.linkedin' | t }}" rel="noopener" target="_blank">{%- render 'icon', name: 'linkedin', class: 'icon--sm' -%}</a></li>{%- endif -%}
            {%- if settings.social_x != blank -%}<li><a href="{{ settings.social_x }}" aria-label="{{ 'general.social.x' | t }}" rel="noopener" target="_blank">{%- render 'icon', name: 'x', class: 'icon--sm' -%}</a></li>{%- endif -%}
          </ul>
        {%- endif -%}
      </div>

      <div class="password__lock" data-animate="fade-up">
        {%- form 'storefront_password', class: 'password__form' -%}
          {%- if form.errors -%}
            <div class="notice notice--error" role="alert">{{ 'password.error' | t }}</div>
          {%- endif -%}
          <label class="password__lock-label" for="Password-{{ uid }}">{{ 'password.login_password_label' | t }}</label>
          <div class="password__lock-field">
            <input type="password" id="Password-{{ uid }}" name="password" placeholder="{{ 'password.login_password_placeholder' | t }}" autocomplete="current-password" required>
            <button type="submit" class="button button--solid">{{ 'password.login_submit' | t }}</button>
          </div>
        {%- endform -%}
      </div>

      <p class="password__admin">{{ 'password.store_owner' | t }} <a href="/admin" class="link">{{ 'password.login_here' | t }}</a></p>
    </div>
  </div>
</section>

{% stylesheet %}
  .password { background-color: rgb(var(--color-background)); color: rgb(var(--color-foreground)); min-height: 100vh; display: flex; align-items: center; }
  .password__wrap { width: 100%; }
  .password__inner { display: flex; flex-direction: column; align-items: center; gap: var(--space-lg); text-align: center; max-width: 40rem; margin-inline: auto; padding-block: var(--space-2xl); }
  .password__brand { color: rgb(var(--color-foreground)); }
  .password__brand .brand-logo__type { font-family: var(--font-display, "Instrument Serif", Georgia, serif); font-size: 1.6rem; letter-spacing: 0.18em; }
  .password__content { display: flex; flex-direction: column; align-items: center; gap: var(--space-md); }
  .password__eyebrow { color: rgb(var(--color-accent)); }
  .password__eyebrow::before { display: none; }
  .password__title { font-size: calc(var(--text-3xl) * var(--heading-scale, 1)); line-height: 1.0; max-width: 18ch; }
  .password__body { font-size: var(--text-lg); color: rgb(var(--color-foreground) / 0.8); max-width: 42ch; }
  .password__message { font-size: var(--text-md); color: rgb(var(--color-foreground) / 0.75); max-width: 42ch; }

  .password__newsletter { width: 100%; max-width: 28rem; margin-top: var(--space-xs); }
  .password__newsletter-heading { font-size: var(--text-sm); margin-bottom: 0.6rem; color: rgb(var(--color-foreground) / 0.7); }
  .password__newsletter-field { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .password__newsletter-field input { flex: 1 1 14rem; }

  .password__social { justify-content: center; gap: 0.75rem; }
  .password__social a { color: rgb(var(--color-foreground) / 0.7); }
  .password__social a:hover { color: rgb(var(--color-accent)); }

  .password__lock { width: 100%; max-width: 28rem; padding-top: var(--space-md); border-top: var(--hairline); }
  .password__lock-label { display: block; font-size: var(--text-sm); margin-bottom: 0.5rem; }
  .password__lock-field { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .password__lock-field input { flex: 1 1 14rem; }
  .password__admin { font-size: var(--text-sm); color: rgb(var(--color-foreground) / 0.6); }
{% endstylesheet %}

{% schema %}
{
  "name": "Password",
  "tag": "section",
  "class": "main-password-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-dark"
    },
    { "type": "checkbox", "id": "show_texture", "label": "Add paper texture", "default": false },
    {
      "type": "header",
      "content": "Content"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "LIMEM" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Opening at the" },
    { "type": "text", "id": "heading_emphasis", "label": "Heading emphasis (italic accent)", "default": "threshold." },
    { "type": "text", "id": "body", "label": "Body", "default": "A more human relationship with technology is almost ready. Enter the password to take a look." },
    {
      "type": "header",
      "content": "Newsletter"
    },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter sign-up", "default": true },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter heading", "default": "Be the first to cross the threshold." },
    {
      "type": "header",
      "content": "Social"
    },
    { "type": "checkbox", "id": "show_social", "label": "Show social links", "default": true }
  ]
}
{% endschema %}
