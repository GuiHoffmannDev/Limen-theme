{%- comment -%}
  Main contact — native Shopify {% form 'contact' %} (name, email, optional
  phone, message) with accessible labels, success and error states. Alongside
  the form: editable brand copy plus real contact details and social links from
  theme settings. Editorial two-column layout.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign uid = section.id | replace: '-', '' | downcase
  assign has_details = false
  if settings.contact_email != blank or settings.contact_phone != blank or settings.contact_address != blank
    assign has_details = true
  endif
  assign social_present = false
  if settings.social_instagram != blank or settings.social_tiktok != blank or settings.social_youtube != blank or settings.social_linkedin != blank or settings.social_x != blank or settings.social_pinterest != blank
    assign social_present = true
  endif
-%}

<section class="contact-section section color-{{ s.color_scheme }}{% if s.show_texture %} has-texture{% endif %}">
  <div class="page-width page-width--wide">
    {%- render 'breadcrumbs' -%}

    <div class="contact-layout">
      <div class="contact-intro" data-animate="fade-up">
        {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
        {%- if s.heading != blank -%}
          <h1 class="contact-intro__title">{{ s.heading | escape }}{% if s.heading_emphasis != blank %} <em>{{ s.heading_emphasis | escape }}</em>{% endif %}</h1>
        {%- endif -%}
        {%- if s.body != blank -%}<div class="contact-intro__body rte">{{ s.body }}</div>{%- endif -%}

        {%- if has_details and s.show_details -%}
          <ul class="contact-details">
            {%- if settings.contact_email != blank -%}
              <li class="contact-details__item">
                {%- render 'icon', name: 'mail', class: 'icon--sm' -%}
                <a href="mailto:{{ settings.contact_email }}" class="link">{{ settings.contact_email }}</a>
              </li>
            {%- endif -%}
            {%- if settings.contact_phone != blank -%}
              <li class="contact-details__item">
                {%- render 'icon', name: 'phone', class: 'icon--sm' -%}
                <a href="tel:{{ settings.contact_phone | remove: ' ' }}" class="link">{{ settings.contact_phone }}</a>
              </li>
            {%- endif -%}
            {%- if settings.contact_address != blank -%}
              <li class="contact-details__item contact-details__item--address">
                {%- render 'icon', name: 'pin', class: 'icon--sm' -%}
                <span>{{ settings.contact_address }}</span>
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}

        {%- if social_present and s.show_social -%}
          <ul class="contact-social cluster" aria-label="{{ 'general.social.label' | t }}">
            {%- if settings.social_instagram != blank -%}<li><a href="{{ settings.social_instagram }}" class="contact-social__link" aria-label="{{ 'general.social.instagram' | t }}" rel="noopener" target="_blank">{%- render 'icon', name: 'instagram' -%}</a></li>{%- endif -%}
            {%- if settings.social_tiktok != blank -%}<li><a href="{{ settings.social_tiktok }}" class="contact-social__link" aria-label="{{ 'general.social.tiktok' | t }}" rel="noopener" target="_blank">{%- render 'icon', name: 'tiktok' -%}</a></li>{%- endif -%}
            {%- if settings.social_youtube != blank -%}<li><a href="{{ settings.social_youtube }}" class="contact-social__link" aria-label="{{ 'general.social.youtube' | t }}" rel="noopener" target="_blank">{%- render 'icon', name: 'youtube' -%}</a></li>{%- endif -%}
            {%- if settings.social_linkedin != blank -%}<li><a href="{{ settings.social_linkedin }}" class="contact-social__link" aria-label="{{ 'general.social.linkedin' | t }}" rel="noopener" target="_blank">{%- render 'icon', name: 'linkedin' -%}</a></li>{%- endif -%}
            {%- if settings.social_x != blank -%}<li><a href="{{ settings.social_x }}" class="contact-social__link" aria-label="{{ 'general.social.x' | t }}" rel="noopener" target="_blank">{%- render 'icon', name: 'x' -%}</a></li>{%- endif -%}
            {%- if settings.social_pinterest != blank -%}<li><a href="{{ settings.social_pinterest }}" class="contact-social__link" aria-label="{{ 'general.social.pinterest' | t }}" rel="noopener" target="_blank">{%- render 'icon', name: 'pinterest' -%}</a></li>{%- endif -%}
          </ul>
        {%- endif -%}
      </div>

      <div class="contact-form-wrap" data-animate="fade-up">
        {%- form 'contact', id: 'ContactForm', class: 'contact-form' -%}
          {%- if form.posted_successfully? -%}
            <p class="notice notice--success" role="status" tabindex="-1" autofocus>
              {%- render 'icon', name: 'check', class: 'icon--sm' -%} {{ 'contact.success' | t }}
            </p>
          {%- else -%}
            {%- if form.errors -%}
              <div class="notice notice--error" role="alert" tabindex="-1" autofocus>
                {{ 'contact.error' | t }}
              </div>
            {%- endif -%}

            <div class="field">
              <label class="field__label" for="ContactName-{{ uid }}">{{ 'contact.name' | t }}</label>
              <input
                type="text"
                id="ContactName-{{ uid }}"
                name="contact[name]"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                autocomplete="name"
                required
              >
            </div>

            <div class="field">
              <label class="field__label" for="ContactEmail-{{ uid }}">{{ 'contact.email' | t }}</label>
              <input
                type="email"
                id="ContactEmail-{{ uid }}"
                name="contact[email]"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                spellcheck="false"
                required
                {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="ContactEmailError-{{ uid }}"{% endif %}
              >
              {%- if form.errors contains 'email' -%}
                <p class="form__message form__message--error" id="ContactEmailError-{{ uid }}">{{ 'contact.email' | t }} {{ form.errors.messages['email'] }}</p>
              {%- endif -%}
            </div>

            <div class="field">
              <label class="field__label" for="ContactPhone-{{ uid }}">{{ 'contact.phone' | t }}</label>
              <input
                type="tel"
                id="ContactPhone-{{ uid }}"
                name="contact[phone]"
                value="{{ form.phone }}"
                autocomplete="tel"
              >
            </div>

            <div class="field">
              <label class="field__label" for="ContactBody-{{ uid }}">{{ 'contact.message' | t }}</label>
              <textarea
                id="ContactBody-{{ uid }}"
                name="contact[body]"
                rows="6"
                required
              >{{ form.body }}</textarea>
            </div>

            <button type="submit" class="button button--solid button--large">{{ 'contact.send' | t }}</button>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .contact-section { background-color: rgb(var(--color-background)); color: rgb(var(--color-foreground)); }
  .contact-layout { display: grid; gap: clamp(2rem, 1rem + 4vw, 5rem); align-items: start; }
  @media (min-width: 990px) { .contact-layout { grid-template-columns: 1fr 1.1fr; } }
  .contact-intro { display: flex; flex-direction: column; gap: var(--space-md); }
  .contact-intro__title { font-size: calc(var(--text-3xl) * var(--heading-scale, 1)); }
  .contact-intro__body { color: rgb(var(--color-foreground) / 0.78); max-width: var(--measure-narrow); }
  .contact-details { display: flex; flex-direction: column; gap: var(--space-xs); margin-top: var(--space-xs); }
  .contact-details__item { display: flex; align-items: center; gap: 0.6rem; font-size: var(--text-md); }
  .contact-details__item--address { align-items: flex-start; }
  .contact-details__item .icon { color: rgb(var(--color-accent)); margin-top: 0.1em; }
  .contact-social { gap: 0.4rem; margin-top: var(--space-sm); }
  .contact-social__link { display: grid; place-content: center; width: 2.6rem; height: 2.6rem; border: var(--hairline); border-radius: 50%; transition: color var(--duration-fast) ease, border-color var(--duration-fast) ease; }
  .contact-social__link:hover { color: rgb(var(--color-accent)); border-color: rgb(var(--color-accent)); }
  .contact-form { display: flex; flex-direction: column; gap: var(--space-md); }
  .contact-form .button { align-self: flex-start; }
  .contact-form .notice { margin-bottom: var(--space-xs); }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "class": "main-contact-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-ivory"
    },
    {
      "type": "checkbox",
      "id": "show_texture",
      "label": "Add paper texture",
      "default": false
    },
    {
      "type": "header",
      "content": "Intro"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start a"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading emphasis (italic accent)",
      "default": "conversation."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Questions about an object, an order, a collaboration? Write to us — a real person will reply.</p>"
    },
    {
      "type": "header",
      "content": "Brand details"
    },
    {
      "type": "checkbox",
      "id": "show_details",
      "label": "Show contact details",
      "info": "Pulls from Theme settings → Contact info.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    }
  ],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}
