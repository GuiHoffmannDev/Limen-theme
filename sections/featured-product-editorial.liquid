{%- comment -%}
  Featured product editorial — one real product, presented like a catalogue
  plate. Image + name + price + short description + variant select + quantity +
  add to cart + stock status + link to the full page. The form is a native
  Shopify product form (works without JS); stage 4 enhances it with AJAX + a
  full option-based variant picker. Placeholder shows only in the editor.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign product = s.product
  assign has_product = false
  if product != blank
    assign has_product = true
  endif
  assign current_variant = product.selected_or_first_available_variant
  assign uid = section.id | replace: '-', '' | downcase
  assign form_id = 'FeaturedProductForm-' | append: uid
  assign desc = s.description
  if desc == blank
    assign desc = product.description | strip_html | truncatewords: 40
  endif
-%}

<section class="featured-product section color-{{ s.color_scheme }}{% if s.show_texture %} has-texture{% endif %}">
  <div class="page-width">
    {%- if has_product -%}
      <div class="featured-product__layout media-text{% if s.layout == 'reverse' %} media-text--reverse{% endif %}">
        <div class="featured-product__media media-text__media" data-animate="{{ settings.animation_reveal_style }}">
          {%- if product.featured_media -%}
            {%- render 'responsive-image',
              image: product.featured_media.preview_image,
              sizes: '(min-width: 750px) 50vw, 100vw',
              widths: '500, 700, 900, 1100, 1400',
              alt: product.featured_media.alt
            -%}
          {%- else -%}
            <div class="placeholder-svg" aria-hidden="true">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg__image' }}</div>
          {%- endif -%}
        </div>

        <div class="featured-product__content media-text__content" data-animate="fade-up" style="--animate-delay: 100ms;">
          {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}

          <h2 class="featured-product__title">{{ s.heading | default: product.title | escape }}</h2>

          {%- render 'price', product: product, variant: current_variant, class: 'featured-product__price' -%}

          {%- if desc != blank -%}
            <div class="featured-product__desc rte">{{ desc }}</div>
          {%- endif -%}

          {%- form 'product', product, id: form_id, class: 'featured-product__form' -%}
            {%- unless product.has_only_default_variant -%}
              <div class="featured-product__variants field">
                <label class="field__label" for="FeaturedVariant-{{ uid }}">{{ 'products.product.choose_options' | t }}</label>
                <div class="select">
                  <select id="FeaturedVariant-{{ uid }}" name="id" data-variant-select>
                    {%- for variant in product.variants -%}
                      <option value="{{ variant.id }}"{% if variant == current_variant %} selected{% endif %}{% unless variant.available %} disabled{% endunless %}>
                        {{ variant.title }}{% unless variant.available %} — {{ 'products.product.sold_out' | t }}{% endunless %}
                      </option>
                    {%- endfor -%}
                  </select>
                </div>
              </div>
            {%- else -%}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
            {%- endunless -%}

            <div class="featured-product__purchase">
              {%- if s.show_quantity -%}
                <div class="field featured-product__qty">
                  <label class="field__label" for="FeaturedQty-{{ uid }}">{{ 'products.product.quantity' | t }}</label>
                  <quantity-input class="quantity">
                    <button type="button" name="minus" class="quantity__button" aria-label="{{ 'products.product.decrease_quantity' | t }}">{%- render 'icon', name: 'minus', class: 'icon--sm' -%}</button>
                    <input id="FeaturedQty-{{ uid }}" class="quantity__input" type="number" name="quantity" value="1" min="1" inputmode="numeric">
                    <button type="button" name="plus" class="quantity__button" aria-label="{{ 'products.product.increase_quantity' | t }}">{%- render 'icon', name: 'plus', class: 'icon--sm' -%}</button>
                  </quantity-input>
                </div>
              {%- endif -%}

              <button
                type="submit"
                name="add"
                class="button button--solid button--large featured-product__add"
                {% unless current_variant.available %}disabled{% endunless %}
                data-add-to-cart
              >
                {%- if current_variant.available -%}{{ 'products.product.add_to_cart' | t }}{%- else -%}{{ 'products.product.sold_out' | t }}{%- endif -%}
              </button>
            </div>

            {%- if s.show_dynamic_checkout -%}
              {{ form | payment_button }}
            {%- endif -%}
          {%- endform -%}

          <div class="featured-product__meta">
            {%- if current_variant.available -%}
              <span class="featured-product__stock featured-product__stock--in">
                <span class="featured-product__dot" aria-hidden="true"></span>{{ 'products.product.inventory_in_stock' | t }}
              </span>
            {%- else -%}
              <span class="featured-product__stock featured-product__stock--out">{{ 'products.product.inventory_out' | t }}</span>
            {%- endif -%}
            <a href="{{ product.url }}" class="link-arrow featured-product__details">{{ 'products.product.view_full_details' | t }}</a>
          </div>
        </div>
      </div>
    {%- elsif request.design_mode -%}
      <div class="featured-product__layout media-text">
        <div class="featured-product__media media-text__media">
          <div class="placeholder-svg" aria-hidden="true">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg__image' }}</div>
        </div>
        <div class="featured-product__content media-text__content">
          <p class="section-header__eyebrow eyebrow">{{ s.eyebrow | escape }}</p>
          <h2 class="featured-product__title">{{ 'onboarding.product_title' | t }}</h2>
          <span class="price"><span class="price__regular">{{ 4800 | money }}</span></span>
          <p class="featured-product__empty">{{ 'onboarding.product_prompt' | t }}</p>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .featured-product { background-color: rgb(var(--color-background)); color: rgb(var(--color-foreground)); }
  .featured-product__media { align-self: start; }
  .featured-product__media img,
  .featured-product__media .placeholder-svg { width: 100%; border-radius: var(--border-radius, 2px); }
  .featured-product__content { gap: var(--space-md); max-width: 46ch; }
  .featured-product__title { font-size: calc(var(--text-2xl) * var(--heading-scale, 1)); }
  .featured-product__price { font-size: var(--text-lg); }
  .featured-product__desc { color: rgb(var(--color-foreground) / 0.78); line-height: var(--leading-relaxed); }
  .featured-product__form { display: flex; flex-direction: column; gap: var(--space-md); }
  .featured-product__variants { max-width: 18rem; }
  .featured-product__purchase { display: flex; flex-wrap: wrap; align-items: flex-end; gap: var(--space-sm); }
  .featured-product__qty { gap: 0.4rem; }
  .featured-product__add { flex: 1 1 12rem; }
  .featured-product__meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem 1.5rem; }
  .featured-product__stock { display: inline-flex; align-items: center; gap: 0.5rem; font-size: var(--text-sm); color: rgb(var(--color-foreground) / 0.7); }
  .featured-product__dot { width: 0.5rem; height: 0.5rem; border-radius: 50%; background: rgb(var(--color-highlight)); }
  .featured-product__stock--out { color: rgb(var(--color-foreground) / 0.5); }
  .featured-product__empty { font-size: var(--text-sm); color: rgb(var(--color-foreground) / 0.55); }
  .featured-product .shopify-payment-button { margin-top: -0.5rem; }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured product",
  "tag": "section",
  "class": "featured-product-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-warm-beige"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        { "value": "default", "label": "Left" },
        { "value": "reverse", "label": "Right" }
      ],
      "default": "default"
    },
    {
      "type": "checkbox",
      "id": "show_texture",
      "label": "Add paper texture",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "In focus"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading override",
      "info": "Leave blank to use the product title."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description override",
      "info": "Leave blank to use the product description."
    },
    {
      "type": "header",
      "content": "Purchase"
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Featured product",
      "settings": {
        "color_scheme": "scheme-warm-beige"
      }
    }
  ]
}
{% endschema %}
