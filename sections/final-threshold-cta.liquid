{%- comment -%}
  Final threshold CTA — the closing invitation. Strong, simple, typographic.
  An optional open-portal arch frames the headline; one or two editable CTAs.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}

<section class="final-cta section color-{{ s.color_scheme }}{% if s.show_texture %} has-texture{% endif %}">
  <div class="page-width page-width--narrow">
    <div class="final-cta__inner" data-animate="threshold">
      {%- if s.show_frame -%}
        <span class="final-cta__frame" aria-hidden="true">
          <svg viewBox="0 0 300 200" fill="none" stroke="currentColor" stroke-width="1.4" preserveAspectRatio="xMidYMax meet">
            <path d="M8 200V92a142 142 0 0 1 284 0v108"/>
          </svg>
        </span>
      {%- endif -%}

      <div class="final-cta__content">
        {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow final-cta__eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
        {%- if s.heading != blank -%}
          <h2 class="final-cta__title display">{{ s.heading | escape }}{% if s.heading_emphasis != blank %} <em>{{ s.heading_emphasis | escape }}</em>{% endif %}</h2>
        {%- endif -%}
        {%- if s.body != blank -%}<p class="final-cta__body">{{ s.body | escape }}</p>{%- endif -%}

        {%- if s.button_primary_label != blank or s.button_secondary_label != blank -%}
          <div class="final-cta__actions cluster">
            {%- if s.button_primary_label != blank -%}
              <a href="{{ s.button_primary_link | default: routes.all_products_collection_url }}" class="button button--solid button--large">{{ s.button_primary_label | escape }}</a>
            {%- endif -%}
            {%- if s.button_secondary_label != blank -%}
              <a href="{{ s.button_secondary_link | default: routes.root_url }}" class="link-arrow final-cta__link">{{ s.button_secondary_label | escape }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .final-cta { background-color: rgb(var(--color-background)); color: rgb(var(--color-foreground)); }
  .final-cta__inner { position: relative; display: flex; justify-content: center; }
  .final-cta__frame {
    position: absolute;
    bottom: -1.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: min(90%, 36rem);
    color: rgb(var(--color-accent) / 0.35);
    z-index: 0;
    pointer-events: none;
  }
  .final-cta__frame svg { width: 100%; height: auto; }
  .final-cta__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    padding-top: var(--space-lg);
  }
  .final-cta__eyebrow::before { display: none; }
  .final-cta__title {
    font-size: calc(var(--text-3xl) * var(--heading-scale, 1));
    line-height: 1.0;
    max-width: 16ch;
  }
  .final-cta__body { font-size: var(--text-lg); color: rgb(var(--color-foreground) / 0.8); max-width: 40ch; }
  .final-cta__actions { justify-content: center; gap: 1.25rem 1.75rem; margin-top: var(--space-xs); }
{% endstylesheet %}

{% schema %}
{
  "name": "Final threshold CTA",
  "tag": "section",
  "class": "final-cta-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-dark"
    },
    {
      "type": "checkbox",
      "id": "show_frame",
      "label": "Show portal arch",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_texture",
      "label": "Add paper texture",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cross the"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading emphasis (italic accent)",
      "default": "threshold."
    },
    {
      "type": "text",
      "id": "body",
      "label": "Body",
      "default": "A more human relationship with technology starts here."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_primary_label",
      "label": "Primary button",
      "default": "Explore products"
    },
    {
      "type": "url",
      "id": "button_primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Secondary link",
      "default": "Discover LIMEM"
    },
    {
      "type": "url",
      "id": "button_secondary_link",
      "label": "Secondary link URL"
    }
  ],
  "presets": [
    {
      "name": "Final threshold CTA",
      "settings": {
        "color_scheme": "scheme-dark"
      }
    }
  ]
}
{% endschema %}
