{%- comment -%}
  Editorial story — the brand's voice, in switchable magazine layouts:
  big statement, two columns, image + text, text on color, a pulled quote, or a
  dictionary "entry" for the word LIMEN. One section, many compositions.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign reverse = false
  if s.image_position == 'right'
    assign reverse = true
  endif
-%}

<section class="story section color-{{ s.color_scheme }} story--{{ s.layout }}{% if s.show_texture %} has-texture{% endif %}">
  <div class="page-width{% if s.layout == 'statement' or s.layout == 'quote' or s.layout == 'entry' %} page-width--narrow{% endif %}">
    {%- case s.layout -%}

      {%- when 'two-column' -%}
        <div class="editorial-columns story__two-col" data-animate="{{ settings.animation_reveal_style }}">
          <div class="story__col-main">
            {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
            {%- if s.heading != blank -%}<h2 class="story__heading">{{ s.heading | escape }}{% if s.heading_emphasis != blank %} <em>{{ s.heading_emphasis | escape }}</em>{% endif %}</h2>{%- endif -%}
          </div>
          <div class="story__col-body">
            {%- if s.body != blank -%}<div class="rte story__body">{{ s.body }}</div>{%- endif -%}
            {%- if s.cta_label != blank -%}<a href="{{ s.cta_link }}" class="link-arrow story__cta">{{ s.cta_label | escape }}</a>{%- endif -%}
          </div>
        </div>

      {%- when 'media' -%}
        <div class="media-text{% if reverse %} media-text--reverse{% endif %} story__media-layout">
          <div class="media-text__media story__media" data-animate="{{ settings.animation_reveal_style }}">
            {%- if s.image != blank -%}
              {%- render 'responsive-image', image: s.image, sizes: '(min-width: 750px) 50vw, 100vw', widths: '500, 700, 900, 1100, 1400' -%}
            {%- else -%}
              <div class="placeholder-svg" aria-hidden="true">{{ 'image' | placeholder_svg_tag: 'placeholder-svg__image' }}</div>
            {%- endif -%}
          </div>
          <div class="media-text__content story__media-content" data-animate="fade-up" style="--animate-delay: 100ms;">
            {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
            {%- if s.heading != blank -%}<h2 class="story__heading">{{ s.heading | escape }}{% if s.heading_emphasis != blank %} <em>{{ s.heading_emphasis | escape }}</em>{% endif %}</h2>{%- endif -%}
            {%- if s.body != blank -%}<div class="rte story__body">{{ s.body }}</div>{%- endif -%}
            {%- if s.cta_label != blank -%}<a href="{{ s.cta_link }}" class="link-arrow story__cta">{{ s.cta_label | escape }}</a>{%- endif -%}
          </div>
        </div>

      {%- when 'quote' -%}
        <figure class="story__quote-figure" data-animate="{{ settings.animation_reveal_style }}">
          {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
          <blockquote class="story__quote statement">{{ s.heading | escape }}{% if s.heading_emphasis != blank %} <em>{{ s.heading_emphasis | escape }}</em>{% endif %}</blockquote>
          {%- if s.body != blank -%}<figcaption class="story__quote-cite">{{ s.body }}</figcaption>{%- endif -%}
        </figure>

      {%- when 'entry' -%}
        <article class="story__entry" data-animate="{{ settings.animation_reveal_style }}">
          {%- if s.eyebrow != blank -%}<p class="story__entry-meta eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
          <h2 class="story__entry-term">{{ s.heading | escape }}{% if s.heading_emphasis != blank %} <em>{{ s.heading_emphasis | escape }}</em>{% endif %}</h2>
          {%- if s.body != blank -%}<div class="rte story__entry-def">{{ s.body }}</div>{%- endif -%}
          {%- if s.cta_label != blank -%}<a href="{{ s.cta_link }}" class="link-arrow story__cta">{{ s.cta_label | escape }}</a>{%- endif -%}
        </article>

      {%- else -%}
        <div class="story__statement-wrap{% if s.text_align == 'center' %} story__statement-wrap--center{% endif %}" data-animate="{{ settings.animation_reveal_style }}">
          {%- if s.eyebrow != blank -%}<p class="section-header__eyebrow eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
          {%- if s.heading != blank -%}<h2 class="story__statement statement statement--full">{{ s.heading | escape }}{% if s.heading_emphasis != blank %} <em>{{ s.heading_emphasis | escape }}</em>{% endif %}</h2>{%- endif -%}
          {%- if s.body != blank -%}<div class="rte story__body story__statement-body">{{ s.body }}</div>{%- endif -%}
          {%- if s.cta_label != blank -%}<a href="{{ s.cta_link }}" class="link-arrow story__cta">{{ s.cta_label | escape }}</a>{%- endif -%}
        </div>

    {%- endcase -%}
  </div>
</section>

{% stylesheet %}
  .story { background-color: rgb(var(--color-background)); color: rgb(var(--color-foreground)); }
  .story__heading { font-size: calc(var(--text-2xl) * var(--heading-scale, 1)); }
  .story__body { color: rgb(var(--color-foreground) / 0.8); line-height: var(--leading-relaxed); }
  .story__body > * + * { margin-top: 1em; }
  .story__cta { margin-top: var(--space-md); }

  .story__two-col .story__col-main { display: flex; flex-direction: column; gap: var(--space-sm); }
  .story__two-col .story__col-body { display: flex; flex-direction: column; gap: var(--space-sm); }

  .story__media-content { display: flex; flex-direction: column; gap: var(--space-md); }

  .story__statement-wrap { display: flex; flex-direction: column; gap: var(--space-md); align-items: flex-start; }
  .story__statement-wrap--center { align-items: center; text-align: center; }
  .story__statement-wrap--center .section-header__eyebrow::before { display: none; }
  .story__statement { max-width: 24ch; }
  .story__statement-body { max-width: 52ch; font-size: var(--text-md); }

  .story__quote-figure { display: flex; flex-direction: column; gap: var(--space-md); margin: 0; }
  .story__quote { max-width: 22ch; }
  .story--quote { text-align: center; }
  .story--quote .story__quote-figure { align-items: center; }
  .story--quote .section-header__eyebrow::before { display: none; }
  .story__quote-cite { font-size: var(--text-sm); color: rgb(var(--color-foreground) / 0.6); }

  .story__entry { display: flex; flex-direction: column; gap: var(--space-sm); border-top: 2px solid rgb(var(--color-foreground)); padding-top: var(--space-md); }
  .story__entry-meta { color: rgb(var(--color-foreground) / 0.55); }
  .story__entry-term { font-size: calc(var(--text-3xl) * var(--heading-scale, 1)); }
  .story__entry-def { font-size: var(--text-lg); line-height: var(--leading-snug); color: rgb(var(--color-foreground) / 0.85); max-width: 48ch; }
  .story__entry-def > * + * { margin-top: 0.75em; }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial story",
  "tag": "section",
  "class": "story-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-ivory"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "statement", "label": "Big statement" },
        { "value": "two-column", "label": "Two columns" },
        { "value": "media", "label": "Image + text" },
        { "value": "quote", "label": "Pulled quote" },
        { "value": "entry", "label": "Dictionary entry" }
      ],
      "default": "two-column"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Statement alignment",
      "info": "Applies to the Big statement layout.",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_texture",
      "label": "Add paper texture",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "li·men · noun"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading / quote",
      "default": "The line between idea and"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading emphasis (italic accent)",
      "default": "object."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body / definition",
      "default": "<p>A threshold is where one state becomes another. LIMEN designs the objects that live on that line — where technology stops being a screen to manage and becomes something you simply reach for.</p>"
    },
    {
      "type": "header",
      "content": "Media & link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (Image + text layout)"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "Editorial story",
      "settings": {
        "layout": "entry",
        "color_scheme": "scheme-ivory"
      }
    }
  ]
}
{% endschema %}
