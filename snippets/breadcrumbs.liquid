{%- comment -%}
  Editorial breadcrumbs (.breadcrumb in sections.css). Honours
  settings.show_breadcrumbs. Built from real Liquid objects per template type.
  The home crumb is always present; the current page is rendered as plain,
  non-linked text with aria-current.

  Accepts:
    class - (string) extra classes
{%- endcomment -%}
{%- if settings.show_breadcrumbs and request.page_type != 'index' -%}
  <nav class="breadcrumb {{ class }}" aria-label="{{ 'general.breadcrumbs.aria_label' | t }}">
    <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t }}</a>

    {%- case request.page_type -%}
      {%- when 'product' -%}
        {%- if collection.url -%}
          <span class="breadcrumb__sep" aria-hidden="true">/</span>
          <a href="{{ collection.url }}">{{ collection.title }}</a>
        {%- endif -%}
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">{{ product.title }}</span>

      {%- when 'collection' -%}
        {%- if current_tags -%}
          <span class="breadcrumb__sep" aria-hidden="true">/</span>
          <a href="{{ collection.url }}">{{ collection.title }}</a>
          <span class="breadcrumb__sep" aria-hidden="true">/</span>
          <span aria-current="page">{{ current_tags | join: ', ' }}</span>
        {%- else -%}
          <span class="breadcrumb__sep" aria-hidden="true">/</span>
          <span aria-current="page">{{ collection.title }}</span>
        {%- endif -%}

      {%- when 'blog' -%}
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">{{ blog.title }}</span>

      {%- when 'article' -%}
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <a href="{{ blog.url }}">{{ blog.title }}</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">{{ article.title }}</span>

      {%- when 'page' -%}
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">{{ page.title }}</span>

      {%- when 'search' -%}
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">{{ 'search.title' | t }}</span>

      {%- else -%}
        {%- if page_title != blank -%}
          <span class="breadcrumb__sep" aria-hidden="true">/</span>
          <span aria-current="page">{{ page_title }}</span>
        {%- endif -%}
    {%- endcase -%}
  </nav>
{%- endif -%}
