{%- comment -%}
  Pagination (.pagination in sections.css). Renders previous / numbered pages /
  next from a paginate object. Accessible: <nav> labelled, current page marked
  with aria-current, disabled ends marked aria-disabled.

  Accepts:
    paginate - (paginate) required, from {% paginate ... %}
    anchor   - (string)   optional #anchor appended to links (e.g. '#ProductGrid')
{%- endcomment -%}
{%- if paginate.parts.size > 0 -%}
  <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
    {%- if paginate.previous -%}
      <a href="{{ paginate.previous.url }}{{ anchor }}" class="pagination__item pagination__item--prev" aria-label="{{ 'general.pagination.previous' | t }}">
        {%- render 'icon', name: 'arrow-left', class: 'icon--sm' -%}
      </a>
    {%- else -%}
      <span class="pagination__item pagination__item--prev" aria-disabled="true" aria-hidden="true">
        {%- render 'icon', name: 'arrow-left', class: 'icon--sm' -%}
      </span>
    {%- endif -%}

    {%- for part in paginate.parts -%}
      {%- if part.is_link -%}
        <a href="{{ part.url }}{{ anchor }}" class="pagination__item" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">{{ part.title }}</a>
      {%- elsif part.title == paginate.current_page -%}
        <span class="pagination__item" aria-current="page" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">{{ part.title }}</span>
      {%- else -%}
        <span class="pagination__item pagination__item--gap" aria-hidden="true">{{ part.title }}</span>
      {%- endif -%}
    {%- endfor -%}

    {%- if paginate.next -%}
      <a href="{{ paginate.next.url }}{{ anchor }}" class="pagination__item pagination__item--next" aria-label="{{ 'general.pagination.next' | t }}">
        {%- render 'icon', name: 'arrow-right', class: 'icon--sm' -%}
      </a>
    {%- else -%}
      <span class="pagination__item pagination__item--next" aria-disabled="true" aria-hidden="true">
        {%- render 'icon', name: 'arrow-right', class: 'icon--sm' -%}
      </span>
    {%- endif -%}
  </nav>
{%- endif -%}
