      "blocks": {
        "c1": { "type": "step", "settings": { "label": "Material", "title": "Anodised aluminium", "note": "Machined from a single billet, bead-blasted and anodised for a warm, matte hand-feel." } },
        "c2": { "type": "step", "settings": { "label": "Process", "title": "Hand-finished", "note": "Each edge is chamfered and checked by hand before assembly." } },
        "c3": { "type": "note", "settings": { "title": "Assembled to last", "note": "<p>Held together with screws, not glue — so it can be opened, repaired and kept in use.</p>" } }
