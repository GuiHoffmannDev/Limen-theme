      }
    },
    "principles": {
      "type": "brand-principles",
      "blocks": {
        "p1": { "type": "principle", "settings": { "title": "Human by design", "body": "Shaped around people first — the technology follows." } },
        "p2": { "type": "principle", "settings": { "title": "Less interface, more interaction", "body": "Fewer screens and menus. More direct, tactile contact." } },
        "p3": { "type": "principle", "settings": { "title": "Built for touch", "body": "Materials and forms made to be held, not just used." } },
        "p4": { "type": "principle", "settings": { "title": "Calm technology", "body": "Present when needed, quiet the rest of the time." } },
        "p5": { "type": "principle", "settings": { "title": "Made to remain useful", "body": "Objects that earn their place and keep it for years." } }
      },
      "block_order": ["p1", "p2", "p3", "p4", "p5"],
      "settings": {
        "color_scheme": "scheme-ivory",
        "layout": "list"
      }
    },
    "featured_collection": {
      "type": "featured-collection-editorial",
