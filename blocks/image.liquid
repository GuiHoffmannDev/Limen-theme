{%- comment -%}
  Theme block: Image. A reorderable, CLS-safe image with optional caption and
  link. Uses the responsive-image snippet (srcset + explicit dimensions). In the
  editor an elegant placeholder appears until an image is chosen.
{%- endcomment -%}
{%- liquid
  assign b = block.settings
  assign ratio_class = 'block-image--ratio-' | append: b.ratio
  assign width_class = 'block-image--' | append: b.width
-%}
<figure class="block-image {{ width_class }} {{ ratio_class }}" {{ block.shopify_attributes }}>
  {%- if b.link != blank -%}<a href="{{ b.link }}" class="block-image__link">{%- endif -%}
  <div class="block-image__media">
    {%- if b.image != blank -%}
      {%- render 'responsive-image',
        image: b.image,
        sizes: '(min-width: 750px) 90vw, 100vw',
        widths: '400, 600, 800, 1100, 1400, 1800',
        crop: b.crop,
        alt: b.image.alt
      -%}
    {%- else -%}
      <div class="placeholder-svg" aria-hidden="true">{{ 'image' | placeholder_svg_tag: 'placeholder-svg__image' }}</div>
    {%- endif -%}
  </div>
  {%- if b.link != blank -%}</a>{%- endif -%}
  {%- if b.caption != blank -%}
    <figcaption class="block-image__caption">{{ b.caption | escape }}</figcaption>
  {%- endif -%}
</figure>

{% stylesheet %}
  .block-image { margin: 0; max-width: var(--measure); }
  .block-image--narrow { max-width: var(--measure-narrow); }
  .block-image--wide { max-width: none; }
  .block-image__media { overflow: hidden; border-radius: var(--border-radius, 2px); background: rgb(var(--color-foreground) / 0.04); }
  .block-image--ratio-square .block-image__media { aspect-ratio: 1 / 1; }
  .block-image--ratio-landscape .block-image__media { aspect-ratio: 4 / 3; }
  .block-image--ratio-wide .block-image__media { aspect-ratio: 16 / 9; }
  .block-image--ratio-portrait .block-image__media { aspect-ratio: 4 / 5; }
  .block-image--ratio-square .block-image__media img,
  .block-image--ratio-landscape .block-image__media img,
  .block-image--ratio-wide .block-image__media img,
  .block-image--ratio-portrait .block-image__media img { width: 100%; height: 100%; object-fit: cover; }
  .block-image__caption { margin-top: var(--space-xs); font-size: var(--text-sm); color: rgb(var(--color-foreground) / 0.6); }
{% endstylesheet %}

{% schema %}
{
  "name": "Image",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select",
      "id": "ratio",
      "label": "Aspect ratio",
      "options": [
        { "value": "natural", "label": "Natural" },
        { "value": "landscape", "label": "Landscape (4:3)" },
        { "value": "wide", "label": "Wide (16:9)" },
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (4:5)" }
      ],
      "default": "landscape"
    },
    {
      "type": "select",
      "id": "crop",
      "label": "Crop",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "normal", "label": "Normal" },
        { "value": "wide", "label": "Wide" }
      ],
      "default": "normal"
    },
    { "type": "text", "id": "caption", "label": "Caption" },
    { "type": "url", "id": "link", "label": "Link (optional)" }
  ],
  "presets": [{ "name": "Image" }]
}
{% endschema %}
