{%- comment -%}
  Theme block: Accordion item. One native <details> row (no JS needed). Stack
  several to build an FAQ. Uses the shared .accordion component styling; an icon
  rotates open via CSS. Each item carries its own hairlines so a single item or
  a run of items reads correctly.
{%- endcomment -%}
{%- liquid
  assign b = block.settings
-%}
<details class="block-accordion accordion__item"{% if b.open_by_default %} open{% endif %} {{ block.shopify_attributes }}>
  <summary class="accordion__summary">
    <span class="block-accordion__title">{{ b.heading | escape }}</span>
    {%- render 'icon', name: 'plus', class: 'icon--sm' -%}
  </summary>
  <div class="accordion__content rte">
    {{ b.content }}
  </div>
</details>

{% stylesheet %}
  .block-accordion { border-top: var(--hairline); }
  .block-accordion + .block-accordion { border-top: 0; }
  .block-accordion__title { font-family: var(--font-body, "IBM Plex Sans", system-ui, sans-serif); }
{% endstylesheet %}

{% schema %}
{
  "name": "Accordion item",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Question" },
    { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Answer the question here.</p>" },
    { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
  ],
  "presets": [{ "name": "Accordion item" }]
}
{% endschema %}
